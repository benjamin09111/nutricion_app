generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                         String           @id @default(uuid())
  email                      String           @unique
  password                   String?

  role                       UserRole         @default(NUTRITIONIST)
  status                     AccountStatus    @default(PENDING)
  createdAt                  DateTime         @map("created_at")@default(now())
  updatedAt                  DateTime         @updatedAt@map("updated_at")
  plan                       SubscriptionPlan @default(FREE)
  subscriptionEndsAt         DateTime?        @map("subscription_ends_at")
  lastLoginAt                DateTime?        @map("last_login_at") @db.Timestamptz(6)
  emailVerificationToken     String?          @unique @map("email_verification_token")
  emailVerificationSentAt    DateTime?        @map("email_verification_sent_at") @db.Timestamptz(6)
  emailVerifiedAt            DateTime?        @map("email_verified_at") @db.Timestamptz(6)
  nutritionist               Nutritionist?
  payments           Payment[]
  subscription       Subscription?
  notifications      Notification[]

  @@index([role, createdAt])
  @@map("accounts")
}

model Nutritionist {
  id                    String                 @id @default(uuid())
  accountId             String                 @unique
  publicSlug            String?                @unique @map("public_slug")
  publicProfileEnabled  Boolean                @default(false) @map("public_profile_enabled")
  fullName              String                 @map("full_name")
  professionalId        String?                @map("professional_id")
  specialty             String?
  phone                 String?
  avatarUrl             String?                @map("avatar_url")
  headline              String?
  bio                   String?
  consultationMode      String                 @default("online") @map("consultation_mode")
  location              String?
  settings              Json?                  @default("{}")
  createdAt             DateTime               @map("created_at")@default(now())
  updatedAt             DateTime               @updatedAt@map("updated_at")
  consultations         Consultation[]
  creations             Creation[]
  ingredientGroups      IngredientGroup[]
  ingredientPreferences IngredientPreference[]
  customIngredients     Ingredient[]
  metricDefinitions     MetricDefinition[]
  account               Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  patients              Patient[]
  patientPortalInvitations PatientPortalInvitation[]
  patientPortalEntries   PatientPortalEntry[]
  patientPortalCheckIns  PatientPortalCheckIn[]
  projects              Project[]
  recipes               Recipe[]
  savedRecipes          RecipeLibrary[]
  resourceSections      ResourceSection[]
  resources             Resource[]
  substitutes           Substitute[]
  createdTags           Tag[]
  appointmentCalendars  AppointmentCalendar[]

  @@index([fullName])
  @@index([publicProfileEnabled, fullName])
  @@index([publicProfileEnabled, consultationMode])
  @@map("nutritionists")
}

model NutritionistInterest {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("nutritionist_interests")
}

model Substitute {
  id             String       @id @default(uuid())
  nutritionistId String       @map("nutritionist_id")
  content        Json
  createdAt      DateTime     @map("created_at")@default(now())
  updatedAt      DateTime     @updatedAt@map("updated_at")
  nutritionist   Nutritionist @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)

  @@index([nutritionistId])
  @@map("substitutes")
}

model Creation {
  id                          String       @id @default(uuid())
  nutritionistId              String       @map("nutritionist_id")
  name                        String
  type                        String
  format                      String       @default("NATIVE")
  content                     Json
  metadata                    Json?
  tags                        String[]     @default([])
  createdAt                   DateTime     @map("created_at")@default(now())
  updatedAt                   DateTime     @updatedAt@map("updated_at")
  nutritionist                Nutritionist @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  sourceProjectsAsCart        Project[]    @relation("ProjectCartCreation")
  sourceProjectsAsDeliverable Project[]    @relation("ProjectDeliverableCreation")
  sourceProjectsAsDiet        Project[]    @relation("ProjectDietCreation")
  sourceProjectsAsRecipes     Project[]    @relation("ProjectRecipeCreation")

  @@index([nutritionistId])
  @@map("creations")
}

model Project {
  id                          String       @id @default(uuid())
  nutritionistId              String       @map("nutritionist_id")
  patientId                   String?      @map("patient_id")
  name                        String
  description                 String?
  mode                        String       @default("CLINICAL")
  status                      String       @default("DRAFT")
  activeDietCreationId        String?      @map("active_diet_creation_id")
  activeRecipeCreationId      String?      @map("active_recipe_creation_id")
  activeCartCreationId        String?      @map("active_cart_creation_id")
  activeDeliverableCreationId String?      @map("active_deliverable_creation_id")
  metadata                    Json?        @default("{}")
  createdAt                   DateTime     @map("created_at")@default(now())
  updatedAt                   DateTime     @updatedAt@map("updated_at")
  activeCartCreation          Creation?    @relation("ProjectCartCreation", fields: [activeCartCreationId], references: [id])
  activeDeliverableCreation   Creation?    @relation("ProjectDeliverableCreation", fields: [activeDeliverableCreationId], references: [id])
  activeDietCreation          Creation?    @relation("ProjectDietCreation", fields: [activeDietCreationId], references: [id])
  activeRecipeCreation        Creation?    @relation("ProjectRecipeCreation", fields: [activeRecipeCreationId], references: [id])
  nutritionist                Nutritionist @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  patient                     Patient?     @relation(fields: [patientId], references: [id])

  @@index([nutritionistId])
  @@index([patientId])
  @@map("projects")
}

model Patient {
  id               String         @id @default(uuid())
  nutritionistId   String         @map("nutritionist_id")
  fullName         String         @map("full_name")
  email            String?
  phone            String?
  documentId       String?        @map("document_id")
  age              Int?           @map("age")
  birthDate        DateTime?      @map("birth_date")
  gender           String?
  height           Float?
  weight           Float?
  createdAt        DateTime       @map("created_at")@default(now())
  updatedAt        DateTime       @updatedAt@map("updated_at")
  dietRestrictions Json?          @default("[]") @map("diet_restrictions")
  clinicalSummary  String?
  customVariables  Json?          @default("[]") @map("custom_variables")
  fitnessGoals     String?        @map("fitness_goals")
  nutritionalFocus String?        @map("nutritional_focus")
  status           String?        @default("Active")
  activityLevel    String?        @map("activity_level")
  tags             String[]       @default([])
  likes            String?
  consultations    Consultation[]
  exams            PatientExam[]
  portalInvitations PatientPortalInvitation[]
  portalEntries     PatientPortalEntry[]
  portalCheckIns    PatientPortalCheckIn[]
  nutritionist     Nutritionist   @relation(fields: [nutritionistId], references: [id])
  projects         Project[]
  appointments     Appointment[]

  @@index([nutritionistId])
  @@map("patients")
}

model PatientExam {
  id         String   @id @default(uuid())
  patientId  String   @map("patient_id")
  name       String
  date       DateTime @default(now())
  fileUrl    String?  @map("file_url")
  notes      String?
  createdAt  DateTime @map("created_at")@default(now())
  updatedAt  DateTime @updatedAt@map("updated_at")
  laboratory String?
  results    Json?    @default("{}")
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_exams")
}

model Consultation {
  id             String       @id @default(uuid())
  patientId      String       @map("patient_id")
  nutritionistId String       @map("nutritionist_id")
  date           DateTime     @default(now())
  title          String
  description    String?
  metrics        Json?        @default("[]")
  createdAt      DateTime     @map("created_at")@default(now())
  updatedAt      DateTime     @updatedAt@map("updated_at")
  nutritionist   Nutritionist @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  patient        Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([nutritionistId])
  @@map("consultations")
}

model PatientPortalInvitation {
  id          String     @id @default(uuid())
  patientId   String     @map("patient_id")
  nutritionistId String  @map("nutritionist_id")
  email       String?
  tokenHash   String     @unique @map("token_hash")
  status      String     @default("ACTIVE")
  expiresAt   DateTime   @map("expires_at")
  revokedAt   DateTime?  @map("revoked_at")
  blockedAt   DateTime?  @map("blocked_at")
  verifiedAt  DateTime?  @map("verified_at")
  lastSentAt  DateTime?  @map("last_sent_at")
  resourceIds String[]   @default([]) @map("resource_ids")
  deliverableCreationIds String[] @default([]) @map("deliverable_creation_ids")
createdAt   DateTime   @map("created_at")@default(now())
updatedAt   DateTime   @updatedAt@map("updated_at")
patient     Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
nutritionist Nutritionist @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
entries     PatientPortalEntry[]
  checkIns    PatientPortalCheckIn[]

  @@index([patientId])
  @@index([nutritionistId])
  @@index([expiresAt])
  @@index([email, status, expiresAt])
  @@index([patientId, nutritionistId, createdAt])
  @@map("patient_portal_invitations")
}

model PatientPortalCheckIn {
  id              String      @id @default(uuid())
  patientId       String      @map("patient_id")
  nutritionistId  String      @map("nutritionist_id")
  invitationId    String?     @map("invitation_id")
  checkInDate     DateTime    @default(now()) @map("check_in_date")
  weight          Float?
  waterLiters     Float?      @map("water_liters")
  activityMinutes Int?        @map("activity_minutes")
  mood            String?
  energy          String?
  hunger          String?
  symptoms        Json        @default("[]")
  meals           Json        @default("[]")
  notes           String?
  photos          Json        @default("[]")
  createdAt       DateTime    @map("created_at")@default(now())
  updatedAt       DateTime    @updatedAt@map("updated_at")
  patient         Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nutritionist    Nutritionist @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  invitation      PatientPortalInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)

  @@index([patientId])
  @@index([nutritionistId])
  @@index([checkInDate])
  @@map("patient_portal_check_ins")
}

model PatientPortalEntry {
  id              String                 @id @default(uuid())
  patientId       String                 @map("patient_id")
  nutritionistId  String                 @map("nutritionist_id")
  invitationId    String?                @map("invitation_id")
  replyToId       String?                @map("reply_to_id")
  kind            String                 @default("QUESTION")
  body            String?
  payload         Json                   @default("{}")
  createdAt       DateTime               @map("created_at")@default(now())
  updatedAt       DateTime               @updatedAt@map("updated_at")
  patient         Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  nutritionist    Nutritionist           @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  invitation      PatientPortalInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  replyTo         PatientPortalEntry?    @relation("PatientPortalEntryReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies         PatientPortalEntry[]   @relation("PatientPortalEntryReplies")

  @@index([patientId])
  @@index([nutritionistId])
  @@index([kind])
  @@index([replyToId])
  @@index([patientId, nutritionistId, createdAt])
  @@map("patient_portal_entries")
}

model Ingredient {
  id                String                 @id @default(uuid())
  name              String
  price             Int                    @default(0)
  unit              String
  amount            Float                  @default(100)
  calories          Float
  proteins          Float
  lipids            Float                  @default(0)
  carbs             Float
  sugars            Float?                 @default(0)
  fiber             Float?                 @default(0)
  sodium            Float?                 @default(0)
  ingredients       String?
  isPublic          Boolean                @default(false) @map("is_public")
  verified          Boolean                @default(false)
  nutritionistId    String?                @map("nutritionist_id")
  createdAt         DateTime               @map("created_at")@default(now())
  updatedAt         DateTime               @updatedAt@map("updated_at")
  brandId           String?                @map("brand_id")
  categoryId        String                 @map("category_id")
  groupEntries      IngredientGroupEntry[]
  preferences       IngredientPreference[]
  brand             IngredientBrand?       @relation(fields: [brandId], references: [id])
  category          IngredientCategory     @relation(fields: [categoryId], references: [id])
  nutritionist      Nutritionist?          @relation(fields: [nutritionistId], references: [id])
  recipeIngredients RecipeIngredient[]
  tags              Tag[]                  @relation("GlobalTags")

  @@index([name])
  @@index([isPublic, verified])
  @@index([nutritionistId])
  @@unique([name, brandId])
  @@map("ingredients")
}

model IngredientBrand {
  id          String       @id @default(uuid())
  name        String       @unique
  ingredients Ingredient[]

  @@map("ingredient_brands")
}

model IngredientCategory {
  id          String       @id @default(uuid())
  name        String       @unique
  ingredients Ingredient[]

  @@map("ingredient_categories")
}

model Tag {
  id               String                 @id @default(uuid())
  name             String                 @unique
  nutritionistId   String?                @map("nutritionist_id")
  nutritionist     Nutritionist?          @relation(fields: [nutritionistId], references: [id])
  ingredients      Ingredient[]           @relation("GlobalTags")
  ingredientGroups IngredientGroup[]      @relation("GroupTags")
  preferences      IngredientPreference[] @relation("PersonalTags")

  @@map("tags")
}

model MetricDefinition {
  id             String        @id @default(uuid())
  name           String        @unique
  unit           String
  key            String        @unique
  nutritionistId String?       @map("nutritionist_id")
  icon           String?       @default("Activity")
  color          String?       @default("#64748b")
  createdAt      DateTime      @map("created_at")@default(now())
  updatedAt      DateTime      @updatedAt@map("updated_at")
  nutritionist   Nutritionist? @relation(fields: [nutritionistId], references: [id])

  @@map("metric_definitions")
}

model IngredientPreference {
  id               String       @id @default(uuid())
  nutritionistId   String       @map("nutritionist_id")
  ingredientId     String       @map("ingredient_id")
  isFavorite       Boolean      @default(false) @map("is_favorite")
  isNotRecommended Boolean      @default(false) @map("is_not_recommended")
  isHidden         Boolean      @default(false) @map("is_hidden")
  ingredient       Ingredient   @relation(fields: [ingredientId], references: [id])
  nutritionist     Nutritionist @relation(fields: [nutritionistId], references: [id])
  tags             Tag[]        @relation("PersonalTags")

  @@unique([nutritionistId, ingredientId])
  @@map("ingredient_preferences")
}

model IngredientGroup {
  id             String                 @id @default(uuid())
  name           String
  type           IngredientGroupType    @default(INGREDIENT)
  nutritionistId String                 @map("nutritionist_id")
  description    String?
  createdAt      DateTime               @map("created_at")@default(now())
  updatedAt      DateTime               @updatedAt@map("updated_at")
  entries        IngredientGroupEntry[]
  nutritionist   Nutritionist           @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  tags           Tag[]                  @relation("GroupTags")

  @@map("ingredient_groups")
}

enum IngredientGroupType {
  INGREDIENT
  RECIPE
}

model IngredientGroupEntry {
  id              String          @id @default(uuid())
  groupId         String          @map("group_id")
  ingredientId    String?         @map("ingredient_id")
  recipeId        String?         @map("recipe_id")
  brandSuggestion String?         @map("brand_suggestion")
  amount          Float?          @default(1)
  unit            String?
  group           IngredientGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  ingredient      Ingredient?     @relation(fields: [ingredientId], references: [id])
  recipe          Recipe?         @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([ingredientId])
  @@index([recipeId])
  @@map("ingredient_group_entries")
}

model FoodPriceRecord {
  id                 String   @id @default(uuid())
  anio               String
  mes                String
  semana             String
  fechaInicio        String   @map("fecha_inicio")
  fechaTermino       String   @map("fecha_termino")
  idRegion           String   @map("id_region")
  region             String
  sector             String
  tipoPuntoMonitoreo String   @map("tipo_punto_monitoreo")
  grupo              String
  producto           String
  unidad             String
  precioMin          Float    @map("precio_minimo")
  precioMax          Float    @map("precio_maximo")
  precioPromedio     Float    @map("precio_promedio")
  createdAt          DateTime @map("created_at")@default(now())

  @@index([producto])
  @@index([region])
  @@index([grupo])
  @@map("food_price_records")
}

model SupportRequest {
  id        String               @id @default(uuid())
  email     String
  message   String?
  type      SupportRequestType
  status    SupportRequestStatus @default(PENDING)
  createdAt DateTime             @map("created_at")@default(now())
  updatedAt DateTime             @updatedAt@map("updated_at")

  @@map("support_requests")
}

model RegistrationRequest {
  id             String        @id @default(uuid())
  fullName       String        @map("full_name")
  email          String
  phone          String?
  professionalId String?       @map("professional_id")
  specialty      String?
  message        String?
  status         RequestStatus @default(PENDING)
  adminNotes     String?       @map("admin_notes")
  createdAt      DateTime      @map("created_at")@default(now())
  updatedAt      DateTime      @updatedAt@map("updated_at")

  @@map("registration_requests")
}

model MembershipPlan {
  id                    String              @id @default(uuid())
  name                  String
  slug                  String              @unique
  description           String?
  price                 Decimal             @db.Decimal(10, 2)
  currency              String              @default("CLP")
  billingPeriod         String              @default("monthly")
  features              Json
  entitlements          Json                @default("{}")
  maxPatients           Int?
  maxStorage            Int?
  isPopular             Boolean             @default(false)
  isActive              Boolean             @default(true)
  displayOrder          Int                 @default(0)
  createdAt             DateTime            @map("created_at")@default(now())
  updatedAt             DateTime            @updatedAt@map("updated_at")
  newSubscriptionEvents SubscriptionEvent[] @relation("NewPlan")
  oldSubscriptionEvents SubscriptionEvent[] @relation("OldPlan")
  subscriptions         Subscription[]

  @@map("membership_plans")
}

model Payment {
  id                 String              @id @default(uuid())
  accountId          String              @map("account_id")
  amount             Decimal             @db.Decimal(10, 2)
  currency           String              @default("CLP")
  status             PaymentStatus       @default(PENDING)
  method             PaymentMethod
  transactionId      String?             @unique @map("transaction_id")
  idempotencyKey     String?             @unique @map("idempotency_key")
  metadata           Json?               @default("{}")
  paidAt             DateTime?           @map("paid_at")
  createdAt          DateTime            @map("created_at")@default(now())
  updatedAt          DateTime            @updatedAt@map("updated_at")
  account            Account             @relation(fields: [accountId], references: [id])
  subscriptionEvents SubscriptionEvent[]

  @@map("payments")
}

model Subscription {
  id                String              @id @default(uuid())
  accountId         String              @unique @map("account_id")
  planId            String              @map("plan_id")
  status            SubscriptionStatus  @default(TRIALING)
  startDate         DateTime            @default(now()) @map("start_date")
  endDate           DateTime?           @map("end_date")
  cancelAtPeriodEnd Boolean             @default(false) @map("cancel_at_period_end")
  canceledAt        DateTime?           @map("canceled_at")
  createdAt         DateTime            @map("created_at")@default(now())
  updatedAt         DateTime            @updatedAt@map("updated_at")
  events            SubscriptionEvent[]
  account           Account             @relation(fields: [accountId], references: [id])
  plan              MembershipPlan      @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model SubscriptionEvent {
  id             String          @id @default(uuid())
  subscriptionId String          @map("subscription_id")
  eventType      String          @map("event_type")
  paymentId      String?         @map("payment_id")
  oldPlanId      String?         @map("old_plan_id")
  newPlanId      String?         @map("new_plan_id")
  metadata       Json?           @default("{}")
  createdAt      DateTime        @map("created_at")@default(now())
  newPlan        MembershipPlan? @relation("NewPlan", fields: [newPlanId], references: [id])
  oldPlan        MembershipPlan? @relation("OldPlan", fields: [oldPlanId], references: [id])
  payment        Payment?        @relation(fields: [paymentId], references: [id])
  subscription   Subscription    @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_events")
}

model DailyMetric {
  id                  String   @id @default(uuid())
  date                DateTime @unique
  totalRevenue        Decimal  @default(0) @map("total_revenue") @db.Decimal(10, 2)
  revenueGrowth       Float    @default(0) @map("revenue_growth")
  totalUsers          Int      @default(0) @map("total_users")
  activeUsers         Int      @default(0) @map("active_users")
  newUsers            Int      @default(0) @map("new_users")
  activeSubscriptions Int      @default(0) @map("active_subscriptions")
  churnRate           Float    @default(0) @map("churn_rate")
  createdAt           DateTime @map("created_at")@default(now())

  @@map("daily_metrics")
}

model Recipe {
  id             String             @id @default(uuid())
  name           String
  description    String?
  preparation    String?
  portionSize    Float              @default(100) @map("portion_size")
  portions       Int                @default(1)
  calories       Float              @default(0)
  proteins       Float              @default(0)
  carbs          Float              @default(0)
  lipids         Float              @default(0)
  fiber          Float?             @default(0)
  sodium         Float?             @default(0)
  isPublic       Boolean            @default(false) @map("is_public")
  nutritionistId String?            @map("nutritionist_id")
  createdAt      DateTime           @map("created_at")@default(now())
  updatedAt      DateTime           @updatedAt@map("updated_at")
  imageUrl       String?            @map("image_url")
  metadata       Json?
  ingredients    RecipeIngredient[]
  groupEntries   IngredientGroupEntry[]
  savedBy        RecipeLibrary[]
  nutritionist   Nutritionist?      @relation(fields: [nutritionistId], references: [id])

  @@index([nutritionistId])
  @@map("recipes")
}

model RecipeIngredient {
  id              String     @id @default(uuid())
  recipeId        String     @map("recipe_id")
  ingredientId    String     @map("ingredient_id")
  amount          Float
  unit            String
  isMain          Boolean    @default(true) @map("is_main")
  brandSuggestion String?    @map("brand_suggestion")
  ingredient      Ingredient @relation(fields: [ingredientId], references: [id])
  recipe          Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([ingredientId])
  @@map("recipe_ingredients")
}

model RecipeLibrary {
  id             String       @id @default(uuid())
  nutritionistId String       @map("nutritionist_id")
  recipeId       String       @map("recipe_id")
  createdAt      DateTime     @map("created_at")@default(now())
  nutritionist   Nutritionist @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  recipe         Recipe       @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([nutritionistId, recipeId])
  @@index([nutritionistId])
  @@index([recipeId])
  @@map("recipe_library")
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  message     String
  type        String   @default("info")
  link        String?
  targetRoles String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @map("created_at")@default(now())
  updatedAt   DateTime @updatedAt@map("updated_at")

  @@map("announcements")
}

model MessageTemplate {
  id        String   @id @default(uuid())
  title     String
  payload   Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @map("created_at") @default(now())
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("message_templates")
}

model Notification {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  title     String
  message   String
  type      String   @default("info")
  link      String?
  readAt    DateTime? @map("read_at")
  metadata  Json?    @default("{}")
  createdAt DateTime  @map("created_at") @default(now())
  updatedAt DateTime  @updatedAt @map("updated_at")
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
  @@index([accountId, readAt])
  @@map("notifications")
}

model Resource {
  id             String        @id @default(uuid())
  nutritionistId String?       @map("nutritionist_id")
  title          String
  content        String
  category       String
  tags           String[]      @default([])
  isPublic       Boolean       @default(false) @map("is_public")
  createdAt      DateTime      @map("created_at")@default(now())
  updatedAt      DateTime      @updatedAt@map("updated_at")
  images         Json?         @default("[]")
  format         String        @default("HTML")
  fileUrl        String?       @map("file_url")
  sources        String?
  nutritionist   Nutritionist? @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)

  @@index([nutritionistId])
  @@map("resources")
}

model ResourceSection {
  id             String        @id @default(uuid())
  nutritionistId String?       @map("nutritionist_id")
  name           String        @unique
  slug           String        @unique
  icon           String?       @default("Layout")
  color          String?       @default("text-emerald-500")
  bg             String?       @default("bg-emerald-50")
  createdAt      DateTime      @map("created_at")@default(now())
  updatedAt      DateTime      @updatedAt@map("updated_at")
  nutritionist   Nutritionist? @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)

  @@index([nutritionistId])
  @@map("resource_sections")
}

